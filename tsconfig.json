{
  "compilerOptions": {
    "target": "es2019",
    "lib": ["es2019"],
    "types": ["node"],
    "module": "commonjs",
    "sourceMap": true,

    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "strictBindCallApply": false,

    "outDir": "./dist"
  },
  "include": ["src"]
}
